# PostgreSQL connection example
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=prosaude_db
DB_USERNAME=pro_user
DB_PASSWORD=SenhaSegura123!
DB_SCHEMA=public
# SSL options: disable, allow, prefer, require, verify-ca, verify-full
DB_SSLMODE=disable

# Optional pool settings
DB_MIN_POOL=1
DB_MAX_POOL=10

# Example for a full connection URL (alternative)
# DATABASE_URL=postgresql://pro_user:SenhaSegura123!@127.0.0.1:5432/prosaude_db

APP_URL=http://localhost/prosaude
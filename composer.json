{
  "name": "angelobrito/prosaude",
  "description": "Sistema de gestão de saúde pública em PHP, migrando para PHP 8 com PSR-4.",
  "type": "project",
  "require": {
    "php": "^8.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    },
    "files": [
      "helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "squizlabs/php_codesniffer": "^4.0",
    "phpstan/phpstan": "^1.11",
    "friendsofphp/php-cs-fixer": "^3.0"
  },
  "scripts": {
    "cs": "phpcs --standard=PSR12 src/",
    "fix": "php-cs-fixer fix src/",
    "analyse": "phpstan analyse src/ --level=5"
  }
}
